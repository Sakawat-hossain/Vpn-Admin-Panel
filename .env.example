APP_NAME=wireguard-backend
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain-here.com
APP_ADMIN="admin"
APP_TIMEZONE='America/New_York'

# Shared secret used by the VPN client app to authenticate to the fast API.
# Generate a long random string (e.g. `php -r "echo bin2hex(random_bytes(32));"`).
APP_FAST_API_KEY=your-value-here

LOG_CHANNEL=daily
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your-database-here
DB_USERNAME=your-db-user-here
DB_PASSWORD=your-db-password-here

DEMO_MODE=false
DEFAULT_LANGUAGE=en
BROADCAST_DRIVER=log
CACHE_DRIVER=file
LICENSE_TYPE=1
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mail.privateemail.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username-here
MAIL_PASSWORD=your-smtp-password-here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-from-address-here
MAIL_FROM_NAME="Your App Name"

# Apple App Store Server API credentials (for in-app purchase validation).
# APPSTORE_PRIVATE_KEY is the FILENAME of the .p8 key file, not the key itself.
# Store the .p8 OUTSIDE the web root or in storage/ and never commit it.
APPSTORE_PASSWORD=your-value-here
APPSTORE_PRIVATE_KEY_ID=your-value-here
APPSTORE_PRIVATE_KEY=AuthKey_XXXXXXXXXX.p8
APPSTORE_ISSUER_ID=your-value-here
APPSTORE_BUNDLE_ID=com.your.bundle.id

# Path to the Google service-account JSON (Play purchase validation / FCM).
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PLAY_PACKAGE_NAME=
